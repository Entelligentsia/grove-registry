{
  "extensions": [
    "rb"
  ],
  "name": "ruby",
  "profile": {
    "containers": [
      [
        "class",
        "name"
      ],
      [
        "module",
        "name"
      ]
    ],
    "function_kinds": [
      "method",
      "singleton_method"
    ],
    "identifier_kinds": [
      "identifier",
      "constant"
    ]
  },
  "source": {
    "repo": "tree-sitter/tree-sitter-ruby",
    "rev": "v0.23.1"
  },
  "version": "0.23.1"
}
